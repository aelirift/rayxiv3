{
  "_meta": {
    "genre": "2d_fighter",
    "description": "Mechanic templates for 2D fighting games. Each mechanic defines what properties it contributes to each role. The union of all mechanics = the complete role schema.",
    "property_categories": {
      "config": "Set at game start, never changes at runtime. DLR fills value. @export var in Godot.",
      "state": "Changes at runtime. DLR fills INITIAL value. var in Godot. Must specify written_by system.",
      "derived": "Computed from other properties. Never stored. Build generates getter. Must specify formula."
    },
    "scope_rules": {
      "role_generic": "Same property structure for ALL instances of this role. Traced once.",
      "instance_unique": "Per-instance. Special moves, character-specific values."
    }
  },

  "roles": {
    "fighter": {
      "description": "Any playable or CPU-controlled character in a fighting game",
      "godot_base_node": "CharacterBody2D",
      "sub_roles": ["playable_fighter", "cpu_fighter"]
    },
    "projectile": {
      "description": "Spawned ranged attack that travels independently",
      "godot_base_node": "Area2D"
    },
    "hud_bar": {
      "description": "Bar display (health, stun, super meter)",
      "godot_base_node": "ProgressBar"
    },
    "hud_text": {
      "description": "Text display (timer, round counter, labels)",
      "godot_base_node": "Label"
    },
    "stage": {
      "description": "Background arena",
      "godot_base_node": "Sprite2D"
    }
  },

  "mechanics": {
    "health_system": {
      "description": "HP tracking, damage application, KO detection",
      "contributes_to_fighter": {
        "config": [
          {"name": "max_health", "type": "int", "default": 1000, "purpose": "Maximum HP at round start"},
          {"name": "damage_reduction", "type": "float", "default": 0.0, "purpose": "Damage multiplier reduction (0.0 = normal, 0.3 = takes 30% less)"}
        ],
        "state": [
          {"name": "current_health", "type": "int", "initial": "max_health", "written_by": "combat_system", "read_by": ["combat_system", "round_system", "animation_system"], "purpose": "Current HP"},
          {"name": "is_ko", "type": "bool", "initial": false, "written_by": "combat_system", "read_by": ["round_system"], "purpose": "True when health <= 0"}
        ],
        "derived": [
          {"name": "health_percent", "formula": "current_health / max_health", "type": "float", "read_by": ["hud_bar"], "purpose": "For health bar display"}
        ]
      },
      "contributes_to_game": {
        "config": [
          {"name": "round_time_seconds", "type": "int", "default": 99, "purpose": "Round timer start value"}
        ]
      },
      "contributes_to_hud_bar": {
        "config": [
          {"name": "target_property", "type": "string", "default": "", "purpose": "Which fighter.property this bar displays (e.g. 'current_health')"},
          {"name": "max_property", "type": "string", "default": "", "purpose": "Which fighter.property is the max (e.g. 'max_health')"}
        ],
        "state": [
          {"name": "display_value", "type": "float", "initial": 1.0, "written_by": "health_system", "read_by": ["animation_system"], "purpose": "Current bar fill (0.0 to 1.0)"}
        ]
      }
    },

    "combat_system": {
      "description": "Hit detection, damage calculation, hitstop, pushback",
      "contributes_to_fighter": {
        "config": [
          {"name": "throw_range", "type": "float", "default": 48, "purpose": "Pixel range for throw"},
          {"name": "throw_damage", "type": "int", "default": 120, "purpose": "Throw damage"}
        ],
        "state": [
          {"name": "hitstop_timer", "type": "int", "initial": 0, "written_by": "combat_system", "read_by": ["combat_system", "input_system", "physics_system", "animation_system"], "purpose": "Frames remaining in hitstop freeze"},
          {"name": "hitstun_timer", "type": "int", "initial": 0, "written_by": "combat_system", "read_by": ["combat_system", "input_system"], "purpose": "Frames remaining in hitstun (cannot act)"},
          {"name": "blockstun_timer", "type": "int", "initial": 0, "written_by": "combat_system", "read_by": ["combat_system", "input_system", "blocking_system"], "purpose": "Frames remaining in blockstun"},
          {"name": "pushback_velocity", "type": "float", "initial": 0.0, "written_by": "combat_system", "read_by": ["physics_system"], "purpose": "Horizontal knockback velocity from hit/block"}
        ]
      },
      "contributes_to_game": {
        "config": [
          {"name": "hitstop_light", "type": "int", "default": 5, "purpose": "Hitstop frames for light attacks"},
          {"name": "hitstop_medium", "type": "int", "default": 8, "purpose": "Hitstop frames for medium attacks"},
          {"name": "hitstop_heavy", "type": "int", "default": 12, "purpose": "Hitstop frames for heavy attacks"},
          {"name": "hitstop_special", "type": "int", "default": 10, "purpose": "Hitstop frames for special moves"},
          {"name": "block_pushback_px", "type": "int", "default": 20, "purpose": "Pushback on block in pixels"}
        ]
      }
    },

    "movement_system": {
      "description": "Walking, jumping, crouching, facing direction",
      "contributes_to_fighter": {
        "config": [
          {"name": "walk_speed", "type": "float", "default": 8.4, "purpose": "Forward walk speed px/frame (scaled for 1080p)"},
          {"name": "back_walk_speed", "type": "float", "default": 6.7, "purpose": "Backward walk speed px/frame (scaled for 1080p)"},
          {"name": "jump_velocity_y", "type": "float", "default": -38.4, "purpose": "Initial jump Y velocity (scaled for 1080p)"},
          {"name": "jump_velocity_x", "type": "float", "default": 9.6, "purpose": "Horizontal air speed (scaled for 1080p)"},
          {"name": "jump_height", "type": "float", "default": 456, "purpose": "Max jump height in pixels (scaled for 1080p)"}
        ],
        "state": [
          {"name": "position", "type": "Vector2", "initial": "Vector2(200, 380)", "written_by": "physics_system", "read_by": ["collision_system", "animation_system", "combat_system"], "purpose": "Current position"},
          {"name": "velocity", "type": "Vector2", "initial": "Vector2(0, 0)", "written_by": "physics_system", "read_by": ["physics_system"], "purpose": "Current velocity"},
          {"name": "facing_direction", "type": "int", "initial": 1, "written_by": "movement_system", "read_by": ["input_system", "combat_system", "animation_system", "projectile_system"], "purpose": "1=right, -1=left. Determines forward/back relative to opponent"},
          {"name": "is_airborne", "type": "bool", "initial": false, "written_by": "physics_system", "read_by": ["input_system", "combat_system", "movement_system"], "purpose": "True when above floor_y"},
          {"name": "is_crouching", "type": "bool", "initial": false, "written_by": "input_system", "read_by": ["combat_system", "blocking_system", "animation_system"], "purpose": "True when holding down"}
        ]
      },
      "contributes_to_game": {
        "config": [
          {"name": "floor_y", "type": "int", "default": 912, "purpose": "Y coordinate of the fighting floor (84% of 1080)"},
          {"name": "gravity", "type": "float", "default": 1.9, "purpose": "Gravity acceleration px/frame² (scaled for 1080p)"},
          {"name": "screen_w", "type": "int", "default": 1920, "purpose": "Stage width in pixels (fullscreen 1080p)"},
          {"name": "screen_h", "type": "int", "default": 1080, "purpose": "Stage height in pixels (fullscreen 1080p)"},
          {"name": "stage_left_bound", "type": "int", "default": 96, "purpose": "Left wall X"},
          {"name": "stage_right_bound", "type": "int", "default": 1824, "purpose": "Right wall X"}
        ]
      }
    },

    "blocking_system": {
      "description": "Stand block, crouch block, chip damage, blockstun",
      "contributes_to_fighter": {
        "config": [
          {"name": "can_block", "type": "bool", "default": true, "purpose": "Whether this fighter can block (false for some bosses)"},
          {"name": "chip_damage_multiplier", "type": "float", "default": 0.25, "purpose": "Damage taken when blocking (fraction of full damage)"}
        ],
        "state": [
          {"name": "is_blocking", "type": "bool", "initial": false, "written_by": "blocking_system", "read_by": ["combat_system", "animation_system"], "purpose": "Currently in block state"},
          {"name": "block_type", "type": "string", "initial": "none", "written_by": "blocking_system", "read_by": ["combat_system"], "purpose": "none/stand/crouch — determines which attacks are blocked"}
        ]
      }
    },

    "stun_system": {
      "description": "Stun meter accumulation, dizzy state, stun recovery",
      "contributes_to_fighter": {
        "config": [
          {"name": "stun_enabled", "type": "bool", "default": true, "purpose": "Whether this fighter can be stunned"},
          {"name": "stun_threshold", "type": "int", "default": 100, "purpose": "Stun meter value that triggers dizzy"},
          {"name": "stun_duration_frames", "type": "int", "default": 300, "purpose": "How long dizzy lasts"},
          {"name": "stun_animation", "type": "string", "default": "", "purpose": "Asset ID for stun animation (per character)"}
        ],
        "state": [
          {"name": "stun_meter", "type": "int", "initial": 0, "written_by": "stun_system", "read_by": ["stun_system", "round_system"], "purpose": "Accumulated stun damage"},
          {"name": "stun_timer", "type": "int", "initial": 0, "written_by": "stun_system", "read_by": ["stun_system", "input_system"], "purpose": "Frames remaining in dizzy state"},
          {"name": "is_stunned", "type": "bool", "initial": false, "written_by": "stun_system", "read_by": ["input_system", "combat_system", "animation_system"], "purpose": "Currently in dizzy state"}
        ]
      },
      "contributes_to_game": {
        "config": [
          {"name": "stun_decay_per_idle_frame", "type": "int", "default": 1, "purpose": "Stun meter reduction per frame when not being hit"}
        ]
      }
    },

    "combo_system": {
      "description": "Hit counting, damage scaling, juggle tracking",
      "contributes_to_fighter": {
        "config": [
          {"name": "juggle_limit", "type": "int", "default": 2, "purpose": "Max additional hits on airborne opponent"},
          {"name": "combo_enabled", "type": "bool", "default": true, "purpose": "Whether combos are tracked for this fighter"}
        ],
        "state": [
          {"name": "combo_count", "type": "int", "initial": 0, "written_by": "combo_system", "read_by": ["combo_system", "animation_system"], "purpose": "Current combo hit count"},
          {"name": "combo_damage_scaling", "type": "float", "initial": 1.0, "written_by": "combo_system", "read_by": ["combat_system"], "purpose": "Damage multiplier that decreases per combo hit"},
          {"name": "juggle_count", "type": "int", "initial": 0, "written_by": "combo_system", "read_by": ["combat_system"], "purpose": "Hits landed on current airborne opponent"}
        ]
      }
    },

    "projectile_system": {
      "description": "Projectile spawning, travel, collision, despawn",
      "contributes_to_fighter": {
        "config": [
          {"name": "has_projectile", "type": "bool", "default": false, "purpose": "Whether this fighter can spawn projectiles"},
          {"name": "projectile_limit", "type": "int", "default": 1, "purpose": "Max projectiles on screen at once"}
        ],
        "state": [
          {"name": "projectile_on_screen", "type": "int", "initial": 0, "written_by": "projectile_system", "read_by": ["projectile_system", "input_system"], "purpose": "Count of active projectiles for this fighter"},
          {"name": "is_firing_projectile", "type": "bool", "initial": false, "written_by": "projectile_system", "read_by": ["input_system", "animation_system"], "purpose": "Locked during projectile startup animation"}
        ]
      },
      "contributes_to_projectile": {
        "config": [
          {"name": "damage", "type": "int", "default": 50, "purpose": "Damage on hit"},
          {"name": "speed", "type": "float", "default": 8.0, "purpose": "Travel speed px/frame"},
          {"name": "lifetime_frames", "type": "int", "default": 180, "purpose": "Max frames before auto-despawn"},
          {"name": "stun_value", "type": "int", "default": 15, "purpose": "Stun meter contribution on hit"},
          {"name": "hitstun_frames", "type": "int", "default": 20, "purpose": "Hitstun inflicted"},
          {"name": "blockstun_frames", "type": "int", "default": 12, "purpose": "Blockstun inflicted"},
          {"name": "hitbox_width", "type": "int", "default": 24, "purpose": "Hitbox width"},
          {"name": "hitbox_height", "type": "int", "default": 24, "purpose": "Hitbox height"},
          {"name": "spawn_offset", "type": "Vector2", "default": "Vector2(40, -20)", "purpose": "Offset from owner position on spawn"}
        ],
        "state": [
          {"name": "position", "type": "Vector2", "initial": "Vector2(0, 0)", "written_by": "physics_system", "read_by": ["collision_system", "animation_system"], "purpose": "Current position"},
          {"name": "owner_id", "type": "string", "initial": "", "written_by": "projectile_system", "read_by": ["collision_system", "combat_system"], "purpose": "Which fighter spawned this"},
          {"name": "active", "type": "bool", "initial": true, "written_by": "projectile_system", "read_by": ["physics_system", "collision_system"], "purpose": "Still alive"},
          {"name": "frames_alive", "type": "int", "initial": 0, "written_by": "physics_system", "read_by": ["projectile_system"], "purpose": "Frame counter for lifetime check"}
        ]
      }
    },

    "input_system": {
      "description": "Input buffering, motion detection, action mapping",
      "contributes_to_fighter": {
        "state": [
          {"name": "input_buffer", "type": "array", "initial": "[]", "written_by": "input_system", "read_by": ["input_system"], "purpose": "Last 20 directional inputs with timestamps"},
          {"name": "current_action", "type": "string", "initial": "none", "written_by": "input_system", "read_by": ["combat_system", "animation_system", "movement_system"], "purpose": "Currently executing action"},
          {"name": "action_frame", "type": "int", "initial": 0, "written_by": "input_system", "read_by": ["combat_system", "animation_system"], "purpose": "Frame counter within current action"}
        ]
      },
      "contributes_to_game": {
        "config": [
          {"name": "input_buffer_size", "type": "int", "default": 20, "purpose": "Max entries in input buffer"},
          {"name": "input_buffer_max_age_ms", "type": "int", "default": 500, "purpose": "Max age of buffer entry before pruning"},
          {"name": "p1_keys", "type": "object", "default": {"left": "A", "right": "D", "up": "W", "down": "S", "lp": "U", "mp": "I", "hp": "O", "lk": "J", "mk": "K", "hk": "L", "start": "SPACE"}, "purpose": "P1 key bindings (global, not per character)"}
        ]
      }
    },

    "animation_system": {
      "description": "State-to-animation mapping, frame timing, sprite management",
      "contributes_to_fighter": {
        "config": [
          {"name": "sprite_scale", "type": "Vector2", "default": "Vector2(1, 1)", "purpose": "Sprite scale factor"},
          {"name": "sprite_height_percent", "type": "float", "default": 0.35, "purpose": "Fighter height as % of screen height"}
        ],
        "state": [
          {"name": "current_animation", "type": "string", "initial": "idle", "written_by": "animation_system", "read_by": ["animation_system"], "purpose": "Currently playing animation name"},
          {"name": "animation_frame", "type": "int", "initial": 0, "written_by": "animation_system", "read_by": ["animation_system", "combat_system"], "purpose": "Current frame within animation"},
          {"name": "sprite_flip_h", "type": "bool", "initial": false, "written_by": "animation_system", "read_by": ["animation_system"], "purpose": "Horizontal flip (based on facing_direction)"}
        ]
      },
      "fighter_animations_required": [
        "idle", "walk_forward", "walk_backward", "jump_up", "jump_forward", "jump_backward",
        "crouch", "crouch_to_stand",
        "light_punch", "medium_punch", "heavy_punch",
        "light_kick", "medium_kick", "heavy_kick",
        "crouch_light_punch", "crouch_medium_punch", "crouch_heavy_punch",
        "crouch_light_kick", "crouch_medium_kick", "crouch_heavy_kick",
        "jump_light_punch", "jump_medium_punch", "jump_heavy_punch",
        "jump_light_kick", "jump_medium_kick", "jump_heavy_kick",
        "hit_stun_high", "hit_stun_low", "hit_stun_air",
        "block_stun_stand", "block_stun_crouch",
        "knockdown", "get_up",
        "throw", "thrown",
        "dizzy",
        "victory", "defeat"
      ]
    },

    "round_system": {
      "description": "Round management, timer, win tracking, transitions",
      "contributes_to_fighter": {
        "state": [
          {"name": "round_wins", "type": "int", "initial": 0, "written_by": "round_system", "read_by": ["round_system"], "purpose": "Rounds won in current match"}
        ]
      },
      "contributes_to_game": {
        "config": [
          {"name": "rounds_to_win", "type": "int", "default": 2, "purpose": "Rounds needed to win the match"},
          {"name": "max_rounds", "type": "int", "default": 3, "purpose": "Maximum rounds per match"}
        ],
        "state": [
          {"name": "current_round", "type": "int", "initial": 1, "written_by": "round_system", "read_by": ["round_system", "animation_system"], "purpose": "Current round number"},
          {"name": "round_timer_frames", "type": "int", "initial": 5940, "written_by": "round_system", "read_by": ["round_system"], "purpose": "Round timer in frames (99s × 60fps)"},
          {"name": "round_state", "type": "string", "initial": "pre_round", "written_by": "round_system", "read_by": ["input_system", "combat_system", "physics_system"], "purpose": "pre_round/fighting/ko/time_up/round_over/match_over"}
        ],
        "derived": [
          {"name": "round_timer_seconds", "formula": "round_timer_frames / 60", "type": "int", "read_by": ["hud_text"], "purpose": "Timer display value"}
        ]
      }
    },

    "charge_system": {
      "description": "Charge input tracking for charge-type special moves",
      "contributes_to_fighter": {
        "config": [
          {"name": "has_charge_moves", "type": "bool", "default": false, "purpose": "Whether this fighter uses charge inputs"},
          {"name": "charge_duration_frames", "type": "int", "default": 60, "purpose": "Frames needed to build full charge"}
        ],
        "state": [
          {"name": "charge_direction", "type": "string", "initial": "none", "written_by": "charge_system", "read_by": ["charge_system", "input_system"], "purpose": "Current charge direction (none/back/down)"},
          {"name": "charge_frames", "type": "int", "initial": 0, "written_by": "charge_system", "read_by": ["charge_system", "input_system"], "purpose": "Frames held in charge direction"},
          {"name": "charge_ready", "type": "bool", "initial": false, "written_by": "charge_system", "read_by": ["input_system"], "purpose": "Charge is complete and ready to release"}
        ]
      }
    },

    "special_move_system": {
      "description": "Special move detection, execution, cooldowns. Instance-unique per character.",
      "scope": "instance_unique",
      "contributes_to_fighter": {
        "config": [
          {"name": "special_move_count", "type": "int", "default": 0, "purpose": "Number of special moves this fighter has"}
        ],
        "state": [
          {"name": "special_cooldown_timer", "type": "int", "initial": 0, "written_by": "special_move_system", "read_by": ["special_move_system", "input_system"], "purpose": "Frames until next special move allowed"}
        ]
      },
      "per_special_move_template": {
        "description": "Each special move adds these properties. Multiply by special_move_count.",
        "config": [
          {"name": "{move}_enabled", "type": "bool", "default": true, "purpose": "Whether this move is available"},
          {"name": "{move}_input_type", "type": "string", "default": "qcf", "purpose": "Input type: qcf/qcb/dp/charge/mash"},
          {"name": "{move}_input_button", "type": "string", "default": "punch", "purpose": "Button category: punch/kick"},
          {"name": "{move}_startup", "type": "int", "default": 12, "purpose": "Startup frames"},
          {"name": "{move}_active", "type": "int", "default": 4, "purpose": "Active frames"},
          {"name": "{move}_recovery", "type": "int", "default": 30, "purpose": "Recovery frames"},
          {"name": "{move}_damage", "type": "int", "default": 80, "purpose": "Base damage"},
          {"name": "{move}_stun_value", "type": "int", "default": 20, "purpose": "Stun meter contribution"},
          {"name": "{move}_cooldown_frames", "type": "int", "default": 45, "purpose": "Cooldown after use"},
          {"name": "{move}_is_projectile", "type": "bool", "default": false, "purpose": "Does this spawn a projectile"},
          {"name": "{move}_invincible_frames", "type": "int", "default": 0, "purpose": "Invincibility frames during startup (e.g. shoryuken)"},
          {"name": "{move}_hits_low", "type": "bool", "default": false, "purpose": "Must be crouch-blocked"},
          {"name": "{move}_is_anti_air", "type": "bool", "default": false, "purpose": "Effective against airborne opponents"},
          {"name": "{move}_animation", "type": "string", "default": "", "purpose": "Animation asset ID"}
        ]
      },
      "normal_attack_template": {
        "description": "Each of the 18 normal attacks (6 strengths × 3 poses). Role-generic — every fighter has all 18.",
        "attacks": [
          "light_punch", "medium_punch", "heavy_punch",
          "light_kick", "medium_kick", "heavy_kick",
          "crouch_light_punch", "crouch_medium_punch", "crouch_heavy_punch",
          "crouch_light_kick", "crouch_medium_kick", "crouch_heavy_kick",
          "jump_light_punch", "jump_medium_punch", "jump_heavy_punch",
          "jump_light_kick", "jump_medium_kick", "jump_heavy_kick"
        ],
        "per_attack": [
          {"name": "{attack}_startup", "type": "int", "purpose": "Startup frames"},
          {"name": "{attack}_active", "type": "int", "purpose": "Active frames"},
          {"name": "{attack}_recovery", "type": "int", "purpose": "Recovery frames"},
          {"name": "{attack}_damage", "type": "int", "purpose": "Base damage"},
          {"name": "{attack}_stun_value", "type": "int", "purpose": "Stun meter contribution"},
          {"name": "{attack}_hitstun", "type": "int", "purpose": "Hitstun inflicted on hit"},
          {"name": "{attack}_blockstun", "type": "int", "purpose": "Blockstun inflicted on block"},
          {"name": "{attack}_hitbox_w", "type": "int", "purpose": "Attack hitbox width"},
          {"name": "{attack}_hitbox_h", "type": "int", "purpose": "Attack hitbox height"},
          {"name": "{attack}_hitbox_offset", "type": "Vector2", "purpose": "Hitbox position relative to fighter"},
          {"name": "{attack}_hits_low", "type": "bool", "default": false, "purpose": "Must be crouch-blocked"},
          {"name": "{attack}_is_overhead", "type": "bool", "default": false, "purpose": "Cannot be crouch-blocked"},
          {"name": "{attack}_cancel_into_special", "type": "bool", "default": false, "purpose": "Can cancel into special move on hit/block"}
        ]
      }
    },

    "ai_system": {
      "description": "CPU opponent decision making",
      "contributes_to_fighter": {
        "config": [
          {"name": "is_cpu", "type": "bool", "default": false, "purpose": "Whether this fighter is CPU-controlled"},
          {"name": "ai_difficulty", "type": "int", "default": 5, "purpose": "AI difficulty level 1-10"},
          {"name": "ai_aggression", "type": "float", "default": 0.5, "purpose": "0.0=defensive, 1.0=aggressive"},
          {"name": "ai_reaction_frames", "type": "int", "default": 12, "purpose": "Minimum frames before AI reacts to an event"}
        ],
        "state": [
          {"name": "ai_decision_timer", "type": "int", "initial": 0, "written_by": "ai_system", "read_by": ["ai_system"], "purpose": "Frames until next AI decision"},
          {"name": "ai_current_plan", "type": "string", "initial": "idle", "written_by": "ai_system", "read_by": ["ai_system", "input_system"], "purpose": "Current AI action plan (maps to input actions)"}
        ]
      }
    },

    "collision_system": {
      "description": "Hitbox/hurtbox overlap detection, push-out",
      "contributes_to_fighter": {
        "config": [
          {"name": "stand_hurtbox", "type": "object", "default": {"x": 0, "y": 0, "w": 40, "h": 80}, "purpose": "Standing hurtbox dimensions"},
          {"name": "crouch_hurtbox", "type": "object", "default": {"x": 0, "y": 22, "w": 44, "h": 58}, "purpose": "Crouching hurtbox dimensions"},
          {"name": "air_hurtbox", "type": "object", "default": {"x": 0, "y": 0, "w": 40, "h": 70}, "purpose": "Airborne hurtbox dimensions"}
        ],
