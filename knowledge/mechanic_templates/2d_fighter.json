{
  "_meta": {
    "genre": "2d_fighter",
    "description": "Mechanic templates for 2D fighting games. Each mechanic defines what properties it contributes to each role. The union of all mechanics = the complete role schema.",
    "property_categories": {
      "config": "Set at game start, never changes at runtime. DLR fills value. @export var in Godot.",
      "state": "Changes at runtime. DLR fills INITIAL value. var in Godot. Must specify written_by system.",
      "derived": "Computed from other properties. Never stored. Build generates getter. Must specify formula."
    },
    "scope_rules": {
      "role_generic": "Same property structure for ALL instances of this role. Traced once.",
      "instance_unique": "Per-instance. Special moves, character-specific values."
    }
  },
  "roles": {
    "fighter": {
      "description": "Any playable or CPU-controlled character in a fighting game",
      "godot_base_node": "CharacterBody2D",
      "sub_roles": [
        "playable_fighter",
        "cpu_fighter"
      ]
    },
    "projectile": {
      "description": "Spawned ranged attack that travels independently",
      "godot_base_node": "Area2D"
    },
    "hud_bar": {
      "description": "Bar display (health, stun, super meter)",
      "godot_base_node": "ProgressBar"
    },
    "hud_text": {
      "description": "Text display (timer, round counter, labels)",
      "godot_base_node": "Label"
    },
    "stage": {
      "description": "Background arena",
      "godot_base_node": "Sprite2D"
    }
  },
  "mechanics": {
    "health_system": {
      "description": "Tracks fighter HP. Objects: fighter, hud_bar. Interactions: combat_system subtracts damage from current_health on hit, round_system reads is_ko to detect round end, hud_bar reads health_percent for fill display. Effects: subtract current_health, set is_ko when health reaches zero, update display_value on hud_bar.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "max_health",
            "type": "int",
            "default": 1000,
            "purpose": "Maximum HP at round start"
          },
          {
            "name": "damage_reduction",
            "type": "float",
            "default": 0.0,
            "purpose": "Damage multiplier reduction (0.0 = normal, 0.3 = takes 30% less)"
          }
        ],
        "state": [
          {
            "name": "current_health",
            "type": "int",
            "initial": "max_health",
            "written_by": "combat_system",
            "read_by": [
              "combat_system",
              "round_system",
              "animation_system"
            ],
            "purpose": "Current HP",
            "write_verb": "subtract"
          },
          {
            "name": "is_ko",
            "type": "bool",
            "initial": false,
            "written_by": "combat_system",
            "read_by": [
              "round_system"
            ],
            "purpose": "True when health <= 0",
            "write_verb": "set"
          }
        ],
        "derived": [
          {
            "name": "health_percent",
            "formula": "current_health / max_health",
            "type": "float",
            "read_by": [
              "hud_bar"
            ],
            "purpose": "For health bar display"
          }
        ]
      },
      "contributes_to_game": {
        "config": [
          {
            "name": "round_time_seconds",
            "type": "int",
            "default": 99,
            "purpose": "Round timer start value"
          }
        ]
      },
      "contributes_to_hud_bar": {
        "config": [
          {
            "name": "target_property",
            "type": "string",
            "default": "",
            "purpose": "Which fighter.property this bar displays (e.g. 'current_health')"
          },
          {
            "name": "max_property",
            "type": "string",
            "default": "",
            "purpose": "Which fighter.property is the max (e.g. 'max_health')"
          }
        ],
        "state": [
          {
            "name": "display_value",
            "type": "float",
            "initial": 1.0,
            "written_by": "health_system",
            "read_by": [
              "animation_system"
            ],
            "purpose": "Current bar fill (0.0 to 1.0)",
            "write_verb": "set"
          }
        ]
      }
    },
    "combat_system": {
      "description": "Hit detection, damage calculation, hitstop freeze, pushback. Objects: fighter, projectile, hitbox, hurtbox. Interactions: reads action_frame and current_action to determine active hitboxes, checks hit_this_frame against opponent hurtbox, applies damage and hitstun, triggers hitstop freeze on both attacker and defender. Effects: subtract current_health, set hitstop_timer and hitstun_timer, apply pushback_velocity.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "throw_range",
            "type": "float",
            "default": 48,
            "purpose": "Pixel range for throw"
          },
          {
            "name": "throw_damage",
            "type": "int",
            "default": 120,
            "purpose": "Throw damage"
          }
        ],
        "state": [
          {
            "name": "hitstop_timer",
            "type": "int",
            "initial": 0,
            "written_by": "combat_system",
            "read_by": [
              "combat_system",
              "input_system",
              "movement_system",
              "animation_system"
            ],
            "purpose": "Frames remaining in hitstop freeze",
            "write_verb": "set"
          },
          {
            "name": "hitstun_timer",
            "type": "int",
            "initial": 0,
            "written_by": "combat_system",
            "read_by": [
              "combat_system",
              "input_system"
            ],
            "purpose": "Frames remaining in hitstun (cannot act)",
            "write_verb": "set"
          },
          {
            "name": "blockstun_timer",
            "type": "int",
            "initial": 0,
            "written_by": "combat_system",
            "read_by": [
              "combat_system",
              "input_system",
              "blocking_system"
            ],
            "purpose": "Frames remaining in blockstun",
            "write_verb": "set"
          },
          {
            "name": "pushback_velocity",
            "type": "float",
            "initial": 0.0,
            "written_by": "combat_system",
            "read_by": [
              "movement_system"
            ],
            "purpose": "Horizontal knockback velocity from hit/block",
            "write_verb": "set"
          }
        ]
      },
      "contributes_to_game": {
        "config": [
          {
            "name": "hitstop_light",
            "type": "int",
            "default": 5,
            "purpose": "Hitstop frames for light attacks"
          },
          {
            "name": "hitstop_medium",
            "type": "int",
            "default": 8,
            "purpose": "Hitstop frames for medium attacks"
          },
          {
            "name": "hitstop_heavy",
            "type": "int",
            "default": 12,
            "purpose": "Hitstop frames for heavy attacks"
          },
          {
            "name": "hitstop_special",
            "type": "int",
            "default": 10,
            "purpose": "Hitstop frames for special moves"
          },
          {
            "name": "block_pushback_px",
            "type": "int",
            "default": 20,
            "purpose": "Pushback on block in pixels"
          }
        ]
      }
    },
    "movement_system": {
      "description": "Walking, jumping, crouching, facing direction, gravity. Objects: fighter, stage. Interactions: reads input direction to determine walk/jump/crouch, movement_system applies gravity and updates position, clamps to stage bounds, always faces opponent for forward/back determination. Effects: set position, set velocity, set facing_direction, set is_airborne, set is_crouching.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "walk_speed",
            "type": "float",
            "default": 8.4,
            "purpose": "Forward walk speed px/frame (scaled for 1080p)"
          },
          {
            "name": "back_walk_speed",
            "type": "float",
            "default": 6.7,
            "purpose": "Backward walk speed px/frame (scaled for 1080p)"
          },
          {
            "name": "jump_velocity_y",
            "type": "float",
            "default": -38.4,
            "purpose": "Initial jump Y velocity (scaled for 1080p)"
          },
          {
            "name": "jump_velocity_x",
            "type": "float",
            "default": 9.6,
            "purpose": "Horizontal air speed (scaled for 1080p)"
          },
          {
            "name": "jump_height",
            "type": "float",
            "default": 456,
            "purpose": "Max jump height in pixels (scaled for 1080p)"
          }
        ],
        "state": [
          {
            "name": "position",
            "type": "Vector2",
            "initial": "Vector2(200, 380)",
            "written_by": "movement_system",
            "read_by": [
              "collision_system",
              "animation_system",
              "combat_system"
            ],
            "purpose": "Current position",
            "write_verb": "set"
          },
          {
            "name": "velocity",
            "type": "Vector2",
            "initial": "Vector2(0, 0)",
            "written_by": "movement_system",
            "read_by": [
              "movement_system"
            ],
            "purpose": "Current velocity",
            "write_verb": "set"
          },
          {
            "name": "facing_direction",
            "type": "int",
            "initial": 1,
            "written_by": "movement_system",
            "read_by": [
              "input_system",
              "combat_system",
              "animation_system",
              "projectile_system"
            ],
            "purpose": "1=right, -1=left. Determines forward/back relative to opponent",
            "write_verb": "set"
          },
          {
            "name": "is_airborne",
            "type": "bool",
            "initial": false,
            "written_by": "movement_system",
            "read_by": [
              "input_system",
              "combat_system",
              "movement_system"
            ],
            "purpose": "True when above floor_y",
            "write_verb": "set"
          },
          {
            "name": "is_crouching",
            "type": "bool",
            "initial": false,
            "written_by": "input_system",
            "read_by": [
              "combat_system",
              "blocking_system",
              "animation_system"
            ],
            "purpose": "True when holding down",
            "write_verb": "set"
          }
        ]
      },
      "contributes_to_game": {
        "config": [
          {
            "name": "floor_y",
            "type": "int",
            "default": 912,
            "purpose": "Y coordinate of the fighting floor (84% of 1080)"
          },
          {
            "name": "gravity",
            "type": "float",
            "default": 1.9,
            "purpose": "Gravity acceleration px/frame\u00b2 (scaled for 1080p)"
          },
          {
            "name": "screen_w",
            "type": "int",
            "default": 1920,
            "purpose": "Stage width in pixels (fullscreen 1080p)"
          },
          {
            "name": "screen_h",
            "type": "int",
            "default": 1080,
            "purpose": "Stage height in pixels (fullscreen 1080p)"
          },
          {
            "name": "stage_left_bound",
            "type": "int",
            "default": 96,
            "purpose": "Left wall X"
          },
          {
            "name": "stage_right_bound",
            "type": "int",
            "default": 1824,
            "purpose": "Right wall X"
          }
        ]
      }
    },
    "blocking_system": {
      "description": "Stand block, crouch block, chip damage, blockstun. Objects: fighter. Interactions: detects holding back away from opponent, distinguishes stand vs crouch block, combat_system applies reduced (chip) damage when blocking, sets blockstun_timer on block. Effects: set is_blocking, set block_type, set blockstun_timer, apply chip_damage_multiplier.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "can_block",
            "type": "bool",
            "default": true,
            "read_by": [
              "blocking_system"
            ],
            "purpose": "Whether this fighter can block (false for some bosses)"
          },
          {
            "name": "chip_damage_multiplier",
            "type": "float",
            "default": 0.25,
            "read_by": [
              "combat_system"
            ],
            "purpose": "Damage taken when blocking (fraction of full damage)"
          }
        ],
        "state": [
          {
            "name": "is_blocking",
            "type": "bool",
            "initial": false,
            "written_by": "blocking_system",
            "read_by": [
              "combat_system",
              "animation_system"
            ],
            "purpose": "Currently in block state",
            "write_verb": "set"
          },
          {
            "name": "block_type",
            "type": "string",
            "initial": "none",
            "written_by": "blocking_system",
            "read_by": [
              "combat_system"
            ],
            "purpose": "none/stand/crouch \u2014 determines which attacks are blocked",
            "write_verb": "set_state"
          }
        ]
      }
    },
    "stun_system": {
      "description": "Stun meter accumulation, dizzy state, stun recovery. Objects: fighter. Interactions: increments stun_meter on each hit, when meter exceeds threshold sets is_stunned, stun_timer counts down dizzy duration, input_system blocks input while stunned. Effects: increment stun_meter, set is_stunned when threshold exceeded, set stun_timer.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "stun_enabled",
            "type": "bool",
            "default": true,
            "purpose": "Whether this fighter can be stunned"
          },
          {
            "name": "stun_threshold",
            "type": "int",
            "default": 100,
            "purpose": "Stun meter value that triggers dizzy"
          },
          {
            "name": "stun_duration_frames",
            "type": "int",
            "default": 300,
            "purpose": "How long dizzy lasts"
          },
          {
            "name": "stun_animation",
            "type": "string",
            "default": "",
            "purpose": "Asset ID for stun animation (per character)"
          }
        ],
        "state": [
          {
            "name": "stun_meter",
            "type": "int",
            "initial": 0,
            "written_by": "stun_system",
            "read_by": [
              "stun_system",
              "round_system"
            ],
            "purpose": "Accumulated stun damage",
            "write_verb": "increment"
          },
          {
            "name": "stun_timer",
            "type": "int",
            "initial": 0,
            "written_by": "stun_system",
            "read_by": [
              "stun_system",
              "input_system"
            ],
            "purpose": "Frames remaining in dizzy state",
            "write_verb": "set"
          },
          {
            "name": "is_stunned",
            "type": "bool",
            "initial": false,
            "written_by": "stun_system",
            "read_by": [
              "input_system",
              "combat_system",
              "animation_system"
            ],
            "purpose": "Currently in dizzy state",
            "write_verb": "set"
          }
        ]
      },
      "contributes_to_game": {
        "config": [
          {
            "name": "stun_decay_per_idle_frame",
            "type": "int",
            "default": 1,
            "purpose": "Stun meter reduction per frame when not being hit"
          }
        ]
      }
    },
    "combo_system": {
      "description": "Hit counting, damage scaling, juggle tracking. Objects: fighter. Interactions: increments combo_count on consecutive hits before recovery, scales combo_damage_scaling down per hit in combo, tracks juggle_count for airborne hits. Effects: increment combo_count, set combo_damage_scaling, increment juggle_count.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "juggle_limit",
            "type": "int",
            "default": 2,
            "purpose": "Max additional hits on airborne opponent"
          },
          {
            "name": "combo_enabled",
            "type": "bool",
            "default": true,
            "purpose": "Whether combos are tracked for this fighter"
          }
        ],
        "state": [
          {
            "name": "combo_count",
            "type": "int",
            "initial": 0,
            "written_by": "combo_system",
            "read_by": [
              "combo_system",
              "animation_system"
            ],
            "purpose": "Current combo hit count",
            "write_verb": "increment"
          },
          {
            "name": "combo_damage_scaling",
            "type": "float",
            "initial": 1.0,
            "written_by": "combo_system",
            "read_by": [
              "combat_system"
            ],
            "purpose": "Damage multiplier that decreases per combo hit",
            "write_verb": "set"
          },
          {
            "name": "juggle_count",
            "type": "int",
            "initial": 0,
            "written_by": "combo_system",
            "read_by": [
              "combat_system"
            ],
            "purpose": "Hits landed on current airborne opponent",
            "write_verb": "increment"
          }
        ]
      }
    },
    "projectile_system": {
      "description": "Projectile spawning, travel, collision, despawn. Objects: fighter, projectile. Interactions: spawns projectile from fighter on special move input, tracks projectile_on_screen count limited by projectile_limit, collision_system detects projectile vs fighter hurtbox, despawns on hit or lifetime expiry. Effects: spawn projectile, increment projectile_on_screen, set is_firing_projectile, set owner_id, set active, increment frames_alive.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "has_projectile",
            "type": "bool",
            "default": false,
            "purpose": "Whether this fighter can spawn projectiles"
          },
          {
            "name": "projectile_limit",
            "type": "int",
            "default": 1,
            "purpose": "Max projectiles on screen at once"
          }
        ],
        "state": [
          {
            "name": "projectile_on_screen",
            "type": "int",
            "initial": 0,
            "written_by": "projectile_system",
            "read_by": [
              "projectile_system",
              "input_system"
            ],
            "purpose": "Count of active projectiles for this fighter",
            "write_verb": "increment"
          },
          {
            "name": "is_firing_projectile",
            "type": "bool",
            "initial": false,
            "written_by": "projectile_system",
            "read_by": [
              "input_system",
              "animation_system"
            ],
            "purpose": "Locked during projectile startup animation",
            "write_verb": "set"
          }
        ]
      },
      "contributes_to_projectile": {
        "config": [
          {
            "name": "damage",
            "type": "int",
            "default": 50,
            "purpose": "Damage on hit"
          },
          {
            "name": "speed",
            "type": "float",
            "default": 8.0,
            "purpose": "Travel speed px/frame"
          },
          {
            "name": "lifetime_frames",
            "type": "int",
            "default": 180,
            "purpose": "Max frames before auto-despawn"
          },
          {
            "name": "stun_value",
            "type": "int",
            "default": 15,
            "purpose": "Stun meter contribution on hit"
          },
          {
            "name": "hitstun_frames",
            "type": "int",
            "default": 20,
            "purpose": "Hitstun inflicted"
          },
          {
            "name": "blockstun_frames",
            "type": "int",
            "default": 12,
            "purpose": "Blockstun inflicted"
          },
          {
            "name": "hitbox_width",
            "type": "int",
            "default": 24,
            "purpose": "Hitbox width"
          },
          {
            "name": "hitbox_height",
            "type": "int",
            "default": 24,
            "purpose": "Hitbox height"
          },
          {
            "name": "spawn_offset",
            "type": "Vector2",
            "default": "Vector2(40, -20)",
            "purpose": "Offset from owner position on spawn"
          }
        ],
        "state": [
          {
            "name": "position",
            "type": "Vector2",
            "initial": "Vector2(0, 0)",
            "written_by": "projectile_system",
            "read_by": [
              "collision_system",
              "animation_system"
            ],
            "purpose": "Current position",
            "write_verb": "set"
          },
          {
            "name": "owner_id",
            "type": "string",
            "initial": "",
            "written_by": "projectile_system",
            "read_by": [
              "collision_system",
              "combat_system"
            ],
            "purpose": "Which fighter spawned this",
            "write_verb": "set"
          },
          {
            "name": "active",
            "type": "bool",
            "initial": true,
            "written_by": "projectile_system",
            "read_by": [
              "projectile_system",
              "collision_system"
            ],
            "purpose": "Still alive",
            "write_verb": "set"
          },
          {
            "name": "frames_alive",
            "type": "int",
            "initial": 0,
            "written_by": "projectile_system",
            "read_by": [
              "projectile_system"
            ],
            "purpose": "Frame counter for lifetime check",
            "write_verb": "increment"
          }
        ]
      }
    },
    "input_system": {
      "description": "Input buffering, motion detection, action mapping. Objects: fighter, button. Interactions: reads keyboard or controller buttons, buffers last 20 directional inputs, detects motion patterns like quarter-circle-forward for special moves, maps button presses to current_action, blocked during hitstop and hitstun. Effects: set input_buffer, set current_action, increment action_frame.",
      "contributes_to_fighter": {
        "state": [
          {
            "name": "input_buffer",
            "type": "array",
            "initial": "[]",
            "written_by": "input_system",
            "read_by": [
              "input_system",
              "blocking_system"
            ],
            "purpose": "Last 20 directional inputs with timestamps",
            "write_verb": "set"
          },
          {
            "name": "current_action",
            "type": "string",
            "initial": "none",
            "written_by": "input_system",
            "read_by": [
              "combat_system",
              "animation_system",
              "movement_system",
              "blocking_system"
            ],
            "purpose": "Currently executing action",
            "write_verb": "set_state"
          },
          {
            "name": "action_frame",
            "type": "int",
            "initial": 0,
            "written_by": "input_system",
            "read_by": [
              "combat_system",
              "animation_system"
            ],
            "purpose": "Frame counter within current action",
            "write_verb": "increment"
          }
        ]
      },
      "contributes_to_game": {
        "config": [
          {
            "name": "input_buffer_size",
            "type": "int",
            "default": 20,
            "purpose": "Max entries in input buffer"
          },
          {
            "name": "input_buffer_max_age_ms",
            "type": "int",
            "default": 500,
            "purpose": "Max age of buffer entry before pruning"
          },
          {
            "name": "p1_keys",
            "type": "object",
            "default": {
              "left": "A",
              "right": "D",
              "up": "W",
              "down": "S",
              "lp": "U",
              "mp": "I",
              "hp": "O",
              "lk": "J",
              "mk": "K",
              "hk": "L",
              "start": "SPACE"
            },
            "purpose": "P1 key bindings (global, not per character)"
          }
        ]
      }
    },
    "animation_system": {
      "description": "State-to-animation mapping, frame timing, sprite management. Objects: fighter, sprite. Interactions: reads current_action and current_health to pick animation, advances animation_frame each tick, flips sprite_flip_h based on facing_direction, displays hit reactions, blocks, KO animations. Effects: set current_animation, increment animation_frame, set sprite_flip_h.",
      "contributes_to_fighter": {
        "config": [
          {
            "name": "sprite_scale",
            "type": "Vector2",
            "default": "Vector2(1, 1)",
            "purpose": "Sprite scale factor"
          },
          {
            "name": "sprite_height_percent",
            "type": "float",
            "default": 0.35,
            "purpose": "Fighter height as % of screen height"
          }
        ],
        "state": [
          {
            "name": "current_animation",
            "type": "string",
            "initial": "idle",
            "written_by": "animation_system",
            "read_by": [
              "animation_system"
            ],
            "purpose": "Currently playing animation name",
            "write_verb": "set_state"
          },
          {
            "name": "animation_frame",
            "type": "int",
            "initial": 0,
            "written_by": "animation_system",
            "read_by": [
              "animation_system",
              "combat_system"
            ],
            "purpose": "Current frame within animation",
            "write_verb": "increment"
          },
          {
            "name": "sprite_flip_h",
