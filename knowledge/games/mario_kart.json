    "ai_racer_count_default": 7,
    "supports_launch_boost": true,
    "supports_items": true,
    "supports_drift_boost": true,
    "supports_boost_pads": true,
    "supports_jump_tricks": true,
    "supports_collectible_speed_resource": true
  },
