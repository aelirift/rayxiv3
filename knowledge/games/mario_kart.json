{
  "_meta": {
    "game": "Modern arcade kart racer reference",
    "genre": "kart_racer",
    "source": "modern kart-racer mechanics and presentation expectations",
    "notes": [
      "Primary gameplay view is a third-person chase camera behind the lead vehicle.",
      "Tracks should feel wide and long, with readable turns, scenery, and item placement.",
      "If the user asks for Mario-Kart-like play, favor the modern mainstream interpretation unless they explicitly ask for retro or Mode-7."
    ]
  },
  "global": {
