    "distance_back": 7.5,
    "height": 3.4,
    "look_ahead_distance": 16.0,
    "fov_degrees": 68,
    "rules": [
      "Keep the player vehicle readable near the bottom-center of the frame.",
      "Expose upcoming turns and enough track width for decision making.",
      "Do not default to top-down as the primary race view for modern kart-racer prompts."
    ]
  },
